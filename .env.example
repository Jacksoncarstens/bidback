# ─── Airtable ──────────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=pat_YOUR_AIRTABLE_API_KEY_HERE
AIRTABLE_BASE_ID=app_YOUR_BASE_ID_HERE
AIRTABLE_TABLE_NAME=Leads

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE
# Price IDs — create in Stripe dashboard then paste here
STRIPE_PRICE_PPA=price_YOUR_STARTER_PRICE_ID
STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE_ID
STRIPE_PRICE_ENT=price_YOUR_ENTERPRISE_PRICE_ID

# ─── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC_YOUR_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
TWILIO_FROM_NUMBER=+1_YOUR_VERIFIED_NUMBER_HERE

# ─── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE

# ─── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_YOUR_TOKEN_HERE

# ─── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE
RESEND_FROM_EMAIL=support@yourdomain.com

# ─── Make.com ──────────────────────────────────────────────────────────────────
MAKE_WEBHOOK_URL=https://hook.make.com/YOUR_WEBHOOK_ID_HERE
MAKE_REPLY_WEBHOOK_URL=https://hook.make.com/YOUR_REPLY_WEBHOOK_ID_HERE

# ─── Tally ─────────────────────────────────────────────────────────────────────
TALLY_WEBHOOK_SECRET=YOUR_TALLY_WEBHOOK_SECRET_HERE

# ─── Telegram (cron notifications) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# ─── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=https://yourdomain.com
VITE_APP_URL=https://yourdomain.com

# ─── Auth ──────────────────────────────────────────────────────────────────────
VITE_ADMIN_PASSWORD=SET_SECURE_ADMIN_PASSWORD_HERE
# Legacy portal passwords (label:password pairs, labels not shown to users)
VITE_PORTAL_PASSWORDS=customer-one:SET_SECURE_PASSWORD_HERE,customer-two:SET_SECURE_PASSWORD_HERE
# JWT signing secret (min 32 chars, random)
JWT_SECRET=SET_SECURE_RANDOM_JWT_SECRET_HERE

# ─── Admin/Migration Scripts ───────────────────────────────────────────────────
# Required to protect /api/admin/* endpoints — set before first deploy
ADMIN_SEED_SECRET=SET_SECURE_ADMIN_SEED_SECRET_HERE
MIGRATION_SECRET=SET_SECURE_MIGRATION_SECRET_HERE
# Values used by seed endpoint to create the initial account
SEED_EMAIL=admin@yourdomain.com
SEED_FIRST_NAME=FirstName
SEED_LAST_NAME=LastName
SEED_COMPANY=Your Company Name
SEED_TIER=Pro
